# Wallet / Polymarket
PRIVATE_KEY=
PROXY_WALLET_ADDRESS=

# Optional CLOB API credentials. Leave empty to auto-derive.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Polygon RPC
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Runtime
DRY_RUN=true

# Dominance / Trend
DOMINANCE_DURATION=5m
DOMINANCE_ASSETS=btc,eth,sol
DOMINANCE_REF_SYMBOLS=btc:btcusdt,eth:ethusdt,sol:solusdt
DOMINANCE_CHAINLINK_STREAMS=btc:btc-usd,eth:eth-usd,sol:sol-usd

DOMINANCE_LATE_ENTRY_WINDOW_SEC=60
DOMINANCE_MIN_TIME_LEFT_SEC=12
DOMINANCE_REF_MOVE_BPS=8
DOMINANCE_REF_CONFIRM_MS=2000
# 0.80 - 0.90 band uses the base rule above: 8bps, full size
DOMINANCE_HIGH_PRICE_CUTOFF=0.90              # 0.90+ band starts here
DOMINANCE_EXTREME_PRICE_CUTOFF=0.95           # 0.95+ extreme band starts here
DOMINANCE_HIGH_PRICE_REF_MOVE_BPS=12          # 0.90 - 0.95 requires 12bps ref move
DOMINANCE_EXTREME_PRICE_REF_MOVE_BPS=16       # 0.95+ requires 16bps ref move

DOMINANCE_ENTRY_CUTOFF=0.80
DOMINANCE_MAX_ENTRY_PRICE=0.98
DOMINANCE_MAX_SPREAD=0.03
DOMINANCE_MIN_TOP_SIZE=25
DOMINANCE_MAX_BOOK_AGE_MS=1500
# Continuous book exit: hard exit on 30% drop, soft exit on 20% drop + weak bid
DOMINANCE_HARD_EXIT_PRICE_DROP_PCT=0.30
DOMINANCE_BOOK_EXIT_PRICE_DROP_PCT=0.20
DOMINANCE_BOOK_EXIT_MIN_BID_SIZE_RATIO=0.35
DOMINANCE_TP_CUTOFF=1.00
DOMINANCE_TIME_CUT_SEC=0
DOMINANCE_TRADE_SIZE=50
